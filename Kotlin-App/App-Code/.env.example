# Environment configuration for the Kotlin Android app.
#
# Copy to `Kotlin-App/App-Code/.env` to override locally.
# Values are base URLs only (no secrets).

# Python REST API base URL (includes version prefix).
REST_API_BASE_URL=https://boardgamestattracker.example.com/api/v1

# Elixir WebSocket base URL (used for live stat updates when implemented).
WS_BASE_URL=wss://boardgamestattracker.example.com/ws
