# Board Game Stat Tracker API — set values locally; never commit .env with real secrets.

# Database
# Async MySQL URL, e.g. mysql+aiomysql://user:password@host:3306/database_name (encode special chars in password)
DATABASE_URL=
# Optional: set to 1, true, or yes to log SQL queries (debug only)
SQL_ECHO=

# JWT and auth (use long random secrets, e.g. openssl rand -hex 32)
JWT_SECRET=
JWT_PUBLISHER_SECRET=
# Access token lifetime in seconds (default 3600)
ACCESS_TOKEN_TTL_SECONDS=
# Refresh token lifetime in days (default 30)
REFRESH_TOKEN_TTL_DAYS=
# Password-reset link token lifetime in seconds (default 3600)
PASSWORD_RESET_TOKEN_TTL_SECONDS=

# Session limit and password reset
# Max sessions a user can create per week, Sunday–Saturday in user timezone (default 2); designers exempt
SESSION_LIMIT_PER_WEEK=
# Base URL for reset-password links, e.g. https://yourapp.com or https://yourapp.com/auth
PASSWORD_RESET_BASE_URL=

# Gmail (for sending password-reset emails)
# Email address that sends reset emails (must match Gmail account)
GMAIL_SENDER=
# OAuth2 access token with gmail.send scope (refresh as needed; or use a service account)
GMAIL_ACCESS_TOKEN=
# Optional: Gmail API base URL (default https://gmail.googleapis.com)
GMAIL_API_BASE_URL=
